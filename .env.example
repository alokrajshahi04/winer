# ===========================================
# WINER — AI Co-founder Configuration
# ===========================================

# ElevenLabs Speech Engine
ELEVENLABS_API_KEY=your_elevenlabs_api_key
SPEECH_ENGINE_ID=your_speech_engine_id
NEXT_PUBLIC_SPEECH_ENGINE_ID=your_speech_engine_id

# LLM Provider (Nebius Studio — OpenAI-compatible)
LLM_API_KEY=your_nebius_api_key
LLM_BASE_URL=https://api.studio.nebius.com/v1
LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
LLM_MODEL_FAST=meta-llama/Meta-Llama-3.1-8B-Instruct

# Appwrite
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_appwrite_api_key
APPWRITE_DATABASE_ID=winer_db

# Collections
APPWRITE_USERS_COLLECTION_ID=users
APPWRITE_PROJECTS_COLLECTION_ID=projects
APPWRITE_CONVERSATIONS_COLLECTION_ID=conversations
APPWRITE_CONTEXT_COLLECTION_ID=user_context

# Modal (for advanced features)
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SPEECH_ENGINE_PORT=3001
